# Copie ce fichier en .env.local et remplis les 3 valeurs.
# Les vraies valeurs sont dans Vercel → Settings → Environment Variables
# (clique sur l'œil 👁️ pour révéler chaque valeur).
# NE JAMAIS committer .env.local (il est ignoré par git).

# Supabase — base de données
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — envoi des emails de notification (formulaire /book)
RESEND_API_KEY=
